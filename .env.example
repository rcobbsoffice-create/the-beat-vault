# =====================================================
# THE BEAT VAULT - ENVIRONMENT VARIABLES
# =====================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
# =====================================================

# =====================================================
# SUPABASE CONFIGURATION
# =====================================================
# Get these from your Supabase project settings:
# https://app.supabase.com/project/_/settings/api

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (SERVER SIDE ONLY - Never expose to client!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =====================================================
# STRIPE CONFIGURATION
# =====================================================
# Get these from: https://dashboard.stripe.com/apikeys

# Publishable key (safe for client-side)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Secret key (SERVER SIDE ONLY)
STRIPE_SECRET_KEY=sk_test_your_secret_key

# Webhook secret (from Stripe webhook settings)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Platform settings
PLATFORM_FEE_PERCENTAGE=15

# =====================================================
# CLOUDFLARE R2 STORAGE
# =====================================================
# Get these from Cloudflare R2 dashboard

R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=beatvault
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-your-bucket-id.r2.dev

# =====================================================
# ACRCLOUD (AUDIO FINGERPRINTING)
# =====================================================
# Get these from: https://console.acrcloud.com

ACRCLOUD_ACCESS_KEY=your-acrcloud-access-key
ACRCLOUD_ACCESS_SECRET=your-acrcloud-secret
ACRCLOUD_HOST=identify-us-west-2.acrcloud.com
ACRCLOUD_BUCKET_NAME=your-acrcloud-bucket

# =====================================================
# PRINTFUL (MERCHANDISE)
# =====================================================
# Get API token from: https://www.printful.com/dashboard/settings

PRINTFUL_API_TOKEN=your-printful-api-token
PRINTFUL_STORE_ID=your-store-id

# =====================================================
# APPLICATION SETTINGS
# =====================================================

# App URL (for callbacks and webhooks)
EXPO_PUBLIC_APP_URL=http://localhost:8081
NEXT_PUBLIC_APP_URL=http://localhost:8081

# Environment
NODE_ENV=development

# =====================================================
# EMAIL CONFIGURATION
# =====================================================
# Choose one provider: resend, sendgrid

EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxxxx
SENDGRID_API_KEY=SG.xxxxx
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=The Beat Vault

# =====================================================
# AI CONTENT GENERATION (OpenAI / Anthropic)
# =====================================================

OPENAI_API_KEY=sk-xxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxx

# =====================================================
# DSP INTEGRATION (Distribution Platforms)
# =====================================================

# Spotify (for analytics)
SPOTIFY_CLIENT_ID=xxxxx
SPOTIFY_CLIENT_SECRET=xxxxx

# YouTube Data API
YOUTUBE_API_KEY=xxxxx

# SoundCloud
SOUNDCLOUD_CLIENT_ID=xxxxx

# DistroKid (if using their API)
DISTROKID_API_KEY=xxxxx

# =====================================================
# FILE PROCESSING SERVICES
# =====================================================
# External audio/image processing endpoints
# These can be Cloudflare Workers or dedicated services

AUDIO_PROCESSOR_URL=https://your-audio-processor.workers.dev
IMAGE_PROCESSOR_URL=https://your-image-processor.workers.dev

# =====================================================
# CRON JOBS
# =====================================================
# Secret key for authenticating cron requests

CRON_SECRET=your-secure-cron-secret-here

# =====================================================
# OPTIONAL: ANALYTICS & MONITORING
# =====================================================

# SENTRY_DSN=your-sentry-dsn
# GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX

# =====================================================
# DEVELOPMENT SETTINGS
# =====================================================

# Enable debug logging
DEBUG=false

# Supabase local development (if using)
# SUPABASE_URL=http://localhost:54321
# SUPABASE_ANON_KEY=your-local-anon-key
